# Django
DJANGO_SECRET_KEY=your-secure-key-here-min-50-chars
DJANGO_DEBUG=False

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (for Django Channels in production)
REDIS_URL=redis://redis:6379/0
USE_REDIS=True

# CORS (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# JWT token lifetimes (seconds)
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=api.example.com,www.api.example.com

# Email (production: use SMTP backend)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@example.com
FRONTEND_URL=https://app.example.com

# Supabase Storage (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_STORAGE_BUCKET=sassblum
